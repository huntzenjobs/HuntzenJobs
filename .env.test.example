# ============================================
# Playwright E2E Tests - Environment Variables
# ============================================
# Copy this file to .env.test and fill with real test credentials

# Test User Credentials (use dedicated test account!)
TEST_USER_EMAIL=test@huntzenjobs.com
TEST_USER_PASSWORD=secure_test_password_here

# Production URLs (for playwright.production.config.ts)
PLAYWRIGHT_BASE_URL=https://huntzenjobs.com
BACKEND_URL=https://huntzenjobs-production.up.railway.app

# Optional: Test accounts for premium features
TEST_USER_FREE_EMAIL=test-free@huntzenjobs.com
TEST_USER_FREE_PASSWORD=password

TEST_USER_PREMIUM_EMAIL=test-premium@huntzenjobs.com
TEST_USER_PREMIUM_PASSWORD=password

TEST_USER_PRO_EMAIL=test-pro@huntzenjobs.com
TEST_USER_PRO_PASSWORD=password
