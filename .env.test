SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# ============================================
# REDIS TEST CONFIGURATION
# ============================================
# Use Redis DB 1 for tests (to avoid conflicts with dev DB 0)
UPSTASH_REDIS_URL=redis://localhost:6379/1
# REST API (mocked for frontend tests)
UPSTASH_REDIS_REST_URL=http://localhost:6379
UPSTASH_REDIS_REST_TOKEN=test_upstash_token_mock

# ============================================
# GROQ API (Use real API key or mock in tests)
# ============================================
# For integration tests, use real key; unit tests should mock this
GROQ_API_KEY=test_groq_api_key_mock

# ============================================
# JOB SEARCH APIs (Mock in tests)
# ============================================
ADZUNA_APP_ID=test_app_id
ADZUNA_API_KEY=test_api_key
SERPAPI_KEY=test_serpapi_key
RAPIDAPI_KEY=test_rapidapi_key
HUNTER_API_KEY=test_hunter_key

# ============================================
# APPLICATION CONFIG
# ============================================
FASTAPI_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CACHE_TTL_HOURS=1  # Shorter cache for tests

# ============================================
# TEST ENVIRONMENT FLAGS
# ============================================
DEBUG=true
LOG_LEVEL=DEBUG
ENVIRONMENT=test
TESTING=true

# Disable external API calls in unit tests (unless explicitly enabled)
MOCK_EXTERNAL_APIS=true

# ============================================
# SENTRY (Disabled for tests)
# ============================================
SENTRY_DSN=  # Empty = disabled
