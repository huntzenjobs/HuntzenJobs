{
  "name": "huntzen-jobsearch",
  "version": "1.0.0",
  "description": "HuntZen - AI-powered Job Search Assistant",
  "private": true,
  "scripts": {
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd tests && python -m pytest -v --tb=short",
    "test:backend:cov": "cd tests && python -m pytest -v --cov=../app --cov=../main --cov-report=html --cov-report=term-missing",
    "test:frontend": "cd frontend-next && npm run test:run",
    "test:frontend:watch": "cd frontend-next && npm run test",
    "test:frontend:cov": "cd frontend-next && npm run test:coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:all": "npm run test && npm run test:e2e",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "cd frontend-next && npm run dev",
    "build": "cd frontend-next && npm run build",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "ruff check . --ignore E501",
    "lint:frontend": "cd frontend-next && npm run lint",
    "playwright:install": "npx playwright install --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "concurrently": "^8.2.0",
    "puppeteer": "^24.36.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
