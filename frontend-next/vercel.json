{
  "git": {
    "deploymentEnabled": {
      "main": false,
      "Production": true,
      "Pre-production": true,
      "test": true
    }
  },
  "github": {
    "silent": false,
    "autoJobCancelation": true
  },
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "regions": ["cdg1"],
  "crons": [
    {
      "path": "/api/cron/reset-quotas",
      "schedule": "0 0 * * *"
    }
  ]
}
