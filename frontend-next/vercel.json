{
  "git": {
    "deploymentEnabled": {
      "main": false,
      "Production": true,
      "Pre-production": true,
      "test": true
    }
  },
  "github": {
    "silent": false,
    "autoJobCancelation": true
  },
  "buildCommand": "node ../scripts/sync-translations.mjs && next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "regions": ["cdg1"],
  "crons": [
    { "path": "/api/cron/reset-quotas",             "schedule": "0 0 * * *" },
    { "path": "/api/cron/job-alerts",               "schedule": "0 8 * * *" },
    { "path": "/api/cron/weekly-summary",           "schedule": "0 9 * * 1" },
    { "path": "/api/cron/retention-notifications",  "schedule": "0 10 * * *" }
  ]
}
