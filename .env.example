# ============================================
# HUNTZEN JOB SEARCH - CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ============================================
# SUPABASE (Auth + Database)
# ============================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api

# Public URL (safe to expose in frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon key (safe to expose in frontend - RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (NEVER expose - backend only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT secret for token verification (Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# Database connection (Settings > Database > Connection string)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxxx:your-password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ============================================
# GROQ (LLM Provider)
# ============================================
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Primary model (powerful, for complex tasks)
PRIMARY_MODEL=llama-3.3-70b-versatile

# Fast model (quick responses, simple tasks)
FAST_MODEL=llama-3.1-8b-instant

# ============================================
# JOB SEARCH APIs
# ============================================

# Adzuna - https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# SerpAPI (Google Jobs) - https://serpapi.com/
SERPAPI_KEY=your_serpapi_key

# RapidAPI (Indeed, LinkedIn scrapers) - https://rapidapi.com/
RAPIDAPI_KEY=your_rapidapi_key

# Hunter.io (Email finder) - https://hunter.io/
HUNTER_API_KEY=your_hunter_api_key

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/disable job providers
ENABLE_ADZUNA=true
ENABLE_SERPAPI=true
ENABLE_REMOTEOK=true

# ElevenLabs Interview Simulator (BETA - disabled by default)
ENABLE_INTERVIEW_SIMULATOR=false
ELEVENLABS_API_KEY=sk_your_elevenlabs_api_key_here
ELEVENLABS_AGENT_ID=agent_your_elevenlabs_agent_id_here

# Requests per minute per IP
RATE_LIMIT=60

# ============================================
# APPLICATION CONFIG
# ============================================

# FastAPI backend URL (for frontend to call)
FASTAPI_URL=http://localhost:8000

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Cache TTL in hours
CACHE_TTL_HOURS=2

# ============================================
# MODAL (Serverless CV Processing) - Issue 2 Fix
# ============================================
# Modal Labs configuration for async CV analysis
# Get your token from: https://modal.com/settings

# Callback endpoint URL (where Modal notifies FastAPI of completion)
# Production: https://your-production-domain.com
# Development: Use ngrok or similar to expose localhost:8000
FASTAPI_CALLBACK_URL=https://your-production-domain.com

# Secret token for securing Modal → FastAPI callbacks
# Generate with: openssl rand -hex 32
# IMPORTANT: Keep this secret! Only Modal and FastAPI should know it.
MODAL_CALLBACK_SECRET=your-random-modal-callback-secret-here-use-openssl-rand-hex-32

# ============================================
# SECURITY & MONITORING
# ============================================

# JWT Configuration (for authentication tokens)
JWT_SECRET=your-random-secret-key-here-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7

# Sentry (Error tracking & monitoring) - https://sentry.io/
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Upstash Redis (Caching & Rate Limiting) - https://console.upstash.com/
# Standard Redis connection (for backend caching)
UPSTASH_REDIS_URL=redis://default:your-password@your-redis.upstash.io:6379
# REST API credentials (for frontend rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# ============================================
# OPTIONAL - Development
# ============================================

# Enable debug mode (set to false in production)
DEBUG=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Supabase JWT Secret (Sprint AUTH - SA-4)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-from-dashboard
